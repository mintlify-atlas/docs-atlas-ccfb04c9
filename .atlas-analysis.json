  "keyFeatures": [
    "CLI tool for running multi-agent coordination benchmarks",
    "Cooperative vs solo agent comparison with 652 tasks",
    "Multiple execution backends: Modal, Docker, and GCP",
    "Redis-based inter-agent messaging and git collaboration",
    "Automated evaluation with patch testing and merge conflict detection",
    "Support for multiple LLM providers and agent frameworks"
  ],
  "publicApiSurface": [
    "cooperbench run - Run agents on benchmark tasks",
    "cooperbench eval - Evaluate completed runs",
    "cooperbench config - Configure execution backends",
    "run() - Python API for running experiments",
    "evaluate() - Python API for evaluation",
    "discover_tasks() - Discover available benchmark tasks",
    "discover_runs() - Discover completed experiment runs"
  ]
